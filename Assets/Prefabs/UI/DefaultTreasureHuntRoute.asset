  routeName: Library Treasure Hunt
  clues:
  - targetNodeID: L2_SectionA
    rawClueText: I hold knowledge of machines and code. My shelves are labelled in
      the 000s. Find me on Level 2 near the large south window.
    geminiClueText:
    useGeminiRephrasing: 1
  - targetNodeID: L2_SectionB
    rawClueText: Wars, empires and ancient civilisations live here. Look for orange
      spine labels in the 900s. Study carrels line the far wall.
    geminiClueText:
    useGeminiRephrasing: 1
  - targetNodeID: L2_Stairs
    rawClueText: Your final destination is not a shelf at all. Find the metal handrails
      and the way between floors on Level 2.
    geminiClueText:
    useGeminiRephrasing: 1
